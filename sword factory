task.spawn(function()
    while true do
        local dt=S.phoneOptimize and 0.15 or 0.1
        task.wait(dt)
        if not farmEnabled then isAttacking=false currentNPCPivot=nil continue end
        if isUnstucking or taskRunning or safeModeActive then isAttacking=false continue end

        local char=getChar()
        local hum=char:FindFirstChildOfClass("Humanoid")
        local rp=char:FindFirstChild("HumanoidRootPart")
        if not hum or not rp then continue end

        local target=nil local livePivot=nil local targetArea=nil

        if S.farmMode=="Map" then
            -- Map mode: just find nearest NPC, selectedArea handled by travel loop
            target,livePivot=findMapTarget(rp)
        else
            -- Priority mode: scan all areas for best priority NPC
            target,livePivot,targetArea=findPriorityTarget()

            if target then
                -- If this NPC is in a different area than we're currently in, travel there
                if targetArea and targetArea~=currentPrioArea then
                    currentPrioArea=targetArea
                    isAttacking=false currentNPCPivot=nil lastTarget=nil
                    smartTravel(targetArea)
                    continue
                end
            else
                -- No priority NPCs found anywhere
                if S.priorityServerHop then
                    setStatus("No priority NPCs - hopping...") task.wait(3) hopServer() continue
                elseif S.priorityKeepFarm then
                    -- Farm best available anywhere
                    target,livePivot,targetArea=findAnyTarget()
                    if target and targetArea and targetArea~=currentPrioArea then
                        currentPrioArea=targetArea
                        isAttacking=false currentNPCPivot=nil lastTarget=nil
                        smartTravel(targetArea)
                        continue
                    end
                else
                    -- Nothing to do — return to home area and wait
                    if isAtBase() or currentPrioArea~=priorityHomeArea then
                        currentPrioArea=priorityHomeArea
                        smartTravel(priorityHomeArea)
                    end
                    isAttacking=false currentNPCPivot=nil
                    setStatus("No priority NPCs - waiting at home")
                    continue
                end
            end
        end

        if not target then
            isAttacking=false currentNPCPivot=nil setStatus("Searching...") continue
        end

        -- Refresh live pivot
        pcall(function() livePivot=target:GetPivot() end)
        if not livePivot then continue end
        currentNPCPivot=livePivot
        local tp=livePivot.Position
        local dist=(rp.Position-tp).Magnitude

        if target~=lastTarget then
            lastTarget=target waypointIdx=1 lastWpIdx=0 lastMoveTgt=nil
            isAttacking=false stuckResetTimer=0
            if S.selectedMovement=="Pathfind" then waypoints=computePath(rp,tp) or {} end
        end

        if dist<S.attackRange then
            isAttacking=true stuckResetTimer=0
            setStatus("⚔ "..target.Name..(targetArea and " ["..targetArea.."]" or ""))
            lastMoveTgt=nil
        else
            isAttacking=false
            if S.selectedMovement=="Teleport" then
                setStatus("Teleporting to "..target.Name)
                pcall(function() rp.CFrame=buildAnchorCFrame(livePivot) end) task.wait(0.1)
            else
                setStatus("Pathing to "..target.Name)
                if lastFarmPos then
                    stuckTimer+=dt stuckResetTimer+=dt
                    if stuckTimer>=0.8 then
                        if (rp.Position-lastFarmPos).Magnitude<0.5 then
                            isUnstucking=true hum:MoveTo(rp.Position) task.wait(0.1)
                            hum.Jump=true task.wait(0.3) hum.Jump=true task.wait(0.3)
                            waypoints=computePath(rp,tp) or {} waypointIdx=1 lastWpIdx=0 lastMoveTgt=nil
                            isUnstucking=false
                        end
                        stuckTimer=0
                    end
                    if stuckResetTimer>=10 then
                        if (rp.Position-lastFarmPos).Magnitude<2 then
                            isAttacking=false isUnstucking=false stuckResetTimer=0
                            lastTarget=nil waypoints={}
                            resetCharacter()
                            repeat task.wait(0.1) until
                                localplr.Character and
                                localplr.Character:FindFirstChildWhichIsA("Humanoid") and
                                localplr.Character:FindFirstChildWhichIsA("Humanoid").Health>0
                            task.wait(3) equipSword() task.wait(1)
                            if S.farmMode=="Priority" then
                                smartTravel(priorityHomeArea)
                            else
                                smartTravel(S.selectedArea)
                            end
                        else stuckResetTimer=0 end
                    end
                end
                lastFarmPos=rp.Position
                if #waypoints>0 and waypointIdx<=#waypoints then
                    local wp=waypoints[waypointIdx]
                    if (rp.Position-wp.Position).Magnitude<4 then waypointIdx+=1 lastMoveTgt=nil end
                    if waypointIdx~=lastWpIdx and waypointIdx<=#waypoints then
                        local nwp=waypoints[waypointIdx]
                        if nwp.Action==Enum.PathWaypointAction.Jump then hum.Jump=true end
                        hum:MoveTo(nwp.Position) lastWpIdx=waypointIdx
                    end
                else
                    if lastMoveTgt~=tp then hum:MoveTo(tp) lastMoveTgt=tp end
                end
            end
        end
    end
end)

