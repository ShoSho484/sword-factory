task.spawn(function()
    local sent={}
    -- Find the friend request remote the game uses (fires silently, no popup)
    local friendRemote=nil
    task.spawn(function()
        -- Common remote names in Roblox games for friend requests
        local remoteNames={"FriendRequest","RequestFriend","AddFriend","SendFriendRequest","Friend"}
        for _,rs in ipairs({game:GetService("ReplicatedStorage"), game:GetService("ReplicatedFirst")}) do
            for _,name in ipairs(remoteNames) do
                local r=rs:FindFirstChild(name,true)
                if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then
                    friendRemote=r break
                end
            end
            if friendRemote then break end
        end
    end)
    while true do task.wait(15)
        if not S.autoAddEnabled then continue end
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr==localplr then continue end
            if sent[plr.UserId] then continue end
            local alreadyFriends=false
            pcall(function() alreadyFriends=localplr:IsFriendsWith(plr.UserId) end)
            if alreadyFriends then sent[plr.UserId]=true continue end
            local lvl=0
            pcall(function()
                local ls=plr:FindFirstChild("leaderstats") if not ls then return end
                for _,stat in ipairs(ls:GetChildren()) do
                    if stat.Name:lower():find("level") then lvl=tonumber(stat.Value) or 0 break end
                end
            end)
            if lvl<S.autoAddMinLevel then continue end
            -- Try game remote first (silent)
            local ok=false
            if friendRemote then
                if friendRemote:IsA("RemoteEvent") then
                    pcall(function() friendRemote:FireServer(plr) ok=true end)
                    if not ok then pcall(function() friendRemote:FireServer(plr.UserId) ok=true end) end
                elseif friendRemote:IsA("RemoteFunction") then
                    pcall(function() friendRemote:InvokeServer(plr) ok=true end)
                end
            end
            -- Fallback: Players service
            if not ok then
                pcall(function() Players:RequestFriendship(plr) ok=true end)
            end
            sent[plr.UserId]=true
            setStatus("Friend req → "..plr.Name)
            task.wait(4)
        end
    end
end)

