local function getSwordInfo(sword)
    local main=sword:FindFirstChild("Main") if not main then return nil end
    local gui=main:FindFirstChild("Gui") or main:FindFirstChildOfClass("SurfaceGui")
    if not gui then return nil end
    local itemInfo=gui:FindFirstChild("ItemInfo") if not itemInfo then return nil end
    local d={}
    local rarity  =itemInfo:FindFirstChild("RarityQuality")
    local worth   =itemInfo:FindFirstChild("Worth")
    local username=itemInfo:FindFirstChild("Username")
    local selling =itemInfo:FindFirstChild("Selling")
    local enchFrame=itemInfo:FindFirstChild("Enchants")
    d.rarity=nil
    if rarity then
        local clean=rarity.Text:gsub("<[^>]+>","")
        for _,r in ipairs(RARITIES) do
            if clean:find(r,1,true) then d.rarity=r break end
        end
    end
    d.worth   = worth    and parsePrice(worth.Text)   or 0
    d.owner   = username and username.Text             or ""
    d.selling = selling  and (selling.Text or "")      or ""
    d.enchants={}
    if enchFrame then
        for i=1,3 do
            local lbl=enchFrame:FindFirstChild("Enchant"..i)
            if lbl and lbl.Text~="" then
                local n,lv=lbl.Text:match("^(.-)%s+([IVXLCDM]+)$")
                if n and lv then table.insert(d.enchants,{name=n,level=romanToNum(lv)}) end
            end
        end
    end
    return d
end

local function presetMatches(data,preset)
    local active={}
    for _,slot in ipairs(preset.slots) do
        if slot.enabled and slot.enchant~="None" then table.insert(active,slot) end
    end
    if #active==0 then return false end
    local avail={}
    for i,e in ipairs(data.enchants) do avail[i]={name=e.name,level=e.level,used=false} end
    for _,slot in ipairs(active) do
        local found=false
        for _,av in ipairs(avail) do
            if not av.used and av.name==slot.enchant and av.level>=slot.minLevel then
                av.used=true found=true break
            end
        end
        if not found then return false end
    end
    return true
end

