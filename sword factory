local function deepLoad(d)
    if type(d)~="table" then return end
    for k,v in pairs(d) do
        if k=="enchantPresets" and type(v)=="table" then
            for i,p in ipairs(v) do
                if S.enchantPresets[i] then
                    S.enchantPresets[i].name     = p.name     or S.enchantPresets[i].name
                    S.enchantPresets[i].enabled  = p.enabled  or false
                    S.enchantPresets[i].movement = p.movement or "Teleport"
                    if type(p.slots)=="table" then
                        for j,sl in ipairs(p.slots) do
                            if S.enchantPresets[i].slots[j] then
                                S.enchantPresets[i].slots[j].enchant  = sl.enchant  or "None"
                                S.enchantPresets[i].slots[j].minLevel = sl.minLevel or 1
                                S.enchantPresets[i].slots[j].enabled  = sl.enabled  or false
                            end
                        end
                    end
                end
            end
        elseif k=="upgradeEnabled" and type(v)=="table" then
            for k2,v2 in pairs(v) do if S.upgradeEnabled[k2]~=nil then S.upgradeEnabled[k2]=v2 end end
        elseif k=="ascenderTraits" and type(v)=="table" then
            for tr,data in pairs(v) do
                if S.ascenderTraits[tr] and type(data)=="table" then
                    S.ascenderTraits[tr].enabled=data.enabled or false
                    S.ascenderTraits[tr].minutes=data.minutes or 1
                end
            end
        elseif DEFAULT_S[k]~=nil and type(v)~="table" then
            S[k]=v
        end
    end
end

