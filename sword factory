local function hopServer()
    pcall(function()
        local ok,data=pcall(function()
            return HttpService:JSONDecode(
                game:HttpGet("https://games.roblox.com/v1/games/"..PLACE_ID.."/servers/Public?sortOrder=Asc&limit=100")
            )
        end)
        if ok and data and data.data and #data.data>0 then
            local cur=game.JobId local cands={}
            for _,srv in ipairs(data.data) do
                if srv.id~=cur and srv.playing and srv.playing<(srv.maxPlayers or 12) then
                    table.insert(cands,srv)
                end
            end
            if #cands>0 then
                TeleportService:TeleportToPlaceInstance(PLACE_ID,cands[math.random(1,#cands)].id,localplr)
                return
            end
        end
        TeleportService:Teleport(PLACE_ID,localplr)
    end)
end

