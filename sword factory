    local dbtn=Instance.new("TextButton",f) dbtn.Size=UDim2.new(0.55,-4,0,20) dbtn.Position=UDim2.new(0.43,0,0.5,-10)
    dbtn.BackgroundColor3=Color3.fromRGB(32,32,52) dbtn.BorderSizePixel=0
    dbtn.Text=selected.." ▾" dbtn.TextColor3=Color3.fromRGB(255,255,255)
    dbtn.TextSize=10 dbtn.Font=Enum.Font.Gotham
    Instance.new("UICorner",dbtn).CornerRadius=UDim.new(0,5)
    local isOpen=false local activeList=nil local conn=nil
    local function closeDD()
        if activeList then activeList:Destroy() activeList=nil end
        if conn then conn:Disconnect() conn=nil end isOpen=false
    end
    local function openDD()
        closeDD() isOpen=true
        local cam=workspace.CurrentCamera
        local sw=cam.ViewportSize.X local sh=cam.ViewportSize.Y
        local bAbs=dbtn.AbsolutePosition local bSz=dbtn.AbsoluteSize
        local listH=math.min(#opts*22+4,160)
        local yPos=bAbs.Y+bSz.Y+2
        if yPos+listH>sh-10 then yPos=bAbs.Y-listH-2 end
        yPos=math.clamp(yPos,4,sh-listH-4)
        local xPos=math.clamp(bAbs.X,4,sw-bSz.X-4)
        local dlist=Instance.new("Frame",screenGui)
        dlist.Size=UDim2.new(0,bSz.X,0,listH) dlist.Position=UDim2.new(0,xPos,0,yPos)
        dlist.BackgroundColor3=Color3.fromRGB(22,22,38) dlist.BorderSizePixel=0 dlist.ZIndex=1000
        Instance.new("UICorner",dlist).CornerRadius=UDim.new(0,6)
        local dsk=Instance.new("UIStroke",dlist) dsk.Color=Color3.fromRGB(60,60,120) dsk.Thickness=1
        local dscroll=Instance.new("ScrollingFrame",dlist)
        dscroll.Size=UDim2.new(1,0,1,0) dscroll.BackgroundTransparency=1
        dscroll.BorderSizePixel=0 dscroll.ScrollBarThickness=3
        dscroll.CanvasSize=UDim2.new(0,0,0,#opts*24) dscroll.ZIndex=1000
        local dl=Instance.new("UIListLayout",dscroll) dl.Padding=UDim.new(0,2)
        local dp=Instance.new("UIPadding",dscroll)
        dp.PaddingTop=UDim.new(0,2) dp.PaddingLeft=UDim.new(0,2) dp.PaddingRight=UDim.new(0,2)
        for _,opt in ipairs(opts) do
            local ob=Instance.new("TextButton",dscroll)
            ob.Size=UDim2.new(1,-4,0,20)
            ob.BackgroundColor3=opt==selected and Color3.fromRGB(55,55,115) or Color3.fromRGB(32,32,52)
            ob.BorderSizePixel=0 ob.Text=opt ob.TextColor3=Color3.fromRGB(215,215,235)
            ob.TextSize=10 ob.Font=Enum.Font.Gotham ob.ZIndex=1001
            Instance.new("UICorner",ob).CornerRadius=UDim.new(0,4)
            ob.MouseButton1Click:Connect(function()
                selected=opt dbtn.Text=opt.." ▾" closeDD()
                if onChange then onChange(opt) end
            end)
        end
        activeList=dlist
        conn=UserInputService.InputBegan:Connect(function(inp2)
            if inp2.UserInputType==Enum.UserInputType.MouseButton1 or inp2.UserInputType==Enum.UserInputType.Touch then
                task.defer(function()
                    if not activeList then return end
                    local mp=UserInputService:GetMouseLocation()
                    local ap=activeList.AbsolutePosition local as=activeList.AbsoluteSize
                    if mp.X<ap.X or mp.X>ap.X+as.X or mp.Y<ap.Y or mp.Y>ap.Y+as.Y then closeDD() end
                end)
            end
        end)
    end
    dbtn.MouseButton1Click:Connect(function() if isOpen then closeDD() else openDD() end end)
    return f, function() return selected end, function(v) selected=v dbtn.Text=v.." ▾" end
end

