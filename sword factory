-- Travel to area only if different from last one, with debounce
local travelCooldown=0
local function smartTravel(areaName)
    if not areaName then return end
    if areaName==lastTraveledArea and tick()-travelCooldown<15 then return end
    lastTraveledArea=areaName travelCooldown=tick()
    setStatus("→ "..areaName)
    travelToArea(areaName) task.wait(8) equipSword()
end

