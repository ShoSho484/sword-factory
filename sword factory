-- Priority mode state
-- homeArea: the area name we started priority farming from (return here when done)
-- currentPrioArea: the area we last teleported to for a priority NPC
local priorityHomeArea = S.selectedArea  -- set when priority farming begins
local currentPrioArea  = nil             -- area we are currently at for priority
local lastTraveledArea = nil             -- tracks last area we told travelToArea

-- Given an NPC area index (1-8), return the area name string
local function areaIndexToName(idx)
    return AREA_NAMES[math.clamp(idx,1,#AREA_NAMES)]
end

-- Find the best priority NPC across all areas (ignores distance — scans everything)
-- Returns: obj, pivot, areaName
local function findPriorityTarget()
    local npcs=workspace:FindFirstChild("NPCs") if not npcs then return nil,nil,nil end
    local minR=S.priorityMinRaw or 0
    local capR=S.priorityCapRaw or 9999
    local best=nil local bestRank=-1 local bestPivot=nil local bestArea=nil
    for _,obj in ipairs(npcs:GetChildren()) do
        local isT=false
        for _,n in ipairs(TARGET_NAMES) do if obj.Name==n then isT=true break end end
        if not isT then continue end
        local h=obj:FindFirstChildWhichIsA("Humanoid") if not h or h.Health<=0 then continue end
        local rank=tonumber(obj:GetAttribute("Rarity")) or 0
        if rank<minR or rank>capR then continue end
        local areaIdx=tonumber(obj:GetAttribute("Area")) or 1
        local areaName=areaIndexToName(areaIdx)
        -- Skip areas the player hasn't unlocked
        if not isAreaUnlocked(areaName) then continue end
        if rank>bestRank then
            local ok,piv=pcall(function() return obj:GetPivot() end) if not ok then continue end
            bestRank=rank best=obj bestPivot=piv bestArea=areaName
        end
    end
    return best,bestPivot,bestArea
end

-- Find best NPC globally (for keepFarming fallback), any rarity
local function findAnyTarget()
    local npcs=workspace:FindFirstChild("NPCs") if not npcs then return nil,nil,nil end
    local best=nil local bestRank=-1 local bestPivot=nil local bestArea=nil
    for _,obj in ipairs(npcs:GetChildren()) do
        local isT=false
        for _,n in ipairs(TARGET_NAMES) do if obj.Name==n then isT=true break end end
        if not isT then continue end
        local h=obj:FindFirstChildWhichIsA("Humanoid") if not h or h.Health<=0 then continue end
        local rank=tonumber(obj:GetAttribute("Rarity")) or 0
        local areaIdx=tonumber(obj:GetAttribute("Area")) or 1
        local areaName=areaIndexToName(areaIdx)
        -- Skip locked areas
        if not isAreaUnlocked(areaName) then continue end
        if rank>bestRank then
            local ok,piv=pcall(function() return obj:GetPivot() end) if not ok then continue end
            bestRank=rank best=obj bestPivot=piv bestArea=areaName
        end
    end
    return best,bestPivot,bestArea
end

-- Map mode: find nearest NPC in current area
local function findMapTarget(rp)
    local npcs=workspace:FindFirstChild("NPCs") if not npcs then return nil,nil end
    local myPos=rp.Position
    local best=nil local bestPiv=nil local bestD=math.huge
    for _,obj in ipairs(npcs:GetChildren()) do
        local isT=false
        for _,n in ipairs(TARGET_NAMES) do if obj.Name==n then isT=true break end end
        if not isT then continue end
        local h=obj:FindFirstChildWhichIsA("Humanoid") if not h or h.Health<=0 then continue end
        local ok,piv=pcall(function() return obj:GetPivot() end) if not ok then continue end
        local d=(myPos-piv.Position).Magnitude
        if d<MAX_TARGET_DISTANCE and d<bestD then bestD=d best=obj bestPiv=piv end
    end
    return best,bestPiv
end

