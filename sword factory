-- Confirmed: Workspace.[name].Head.Gui.User text = '<b><font ...>[Lv 413]</font></b> name'
local function getPlayerLevel()
    if tick()-_lastLevelCheck < 10 then return _cachedPlayerLevel end
    _lastLevelCheck = tick()
    local lvl = 0
    pcall(function()
        local char=localplr.Character if not char then return end
        local head=char:FindFirstChild("Head") if not head then return end
        local gui=head:FindFirstChild("Gui") if not gui then return end
        local userLbl=gui:FindFirstChild("User") if not userLbl then return end
        local n=tostring(userLbl.Text):match("%[Lv%s*(%d+)%]")
        if n then lvl=tonumber(n) or 0 end
    end)
    _cachedPlayerLevel=lvl
    return lvl
end

-- Confirmed from pathfinder:
--   Areas.List.[AreaName].Main (TextButton)
--   .Main.Title: area name when accessible, '🔒 LOCKED' when locked by purchase
--   .Main.Level: 'LEVEL 0-19' (range) or 'LEVEL 420+' (minimum) or 'LEVEL 10+' etc.
-- A player can enter if their level is >= the minimum shown.
-- For ranges like '0-19' the player must be <= max. For '420+' they must be >= 420.
local function isAreaUnlocked(areaName)
    if unlockedCache[areaName]==true then return true end
    local result=false
    pcall(function()
        local areaList=localplr.PlayerGui.PlotUI.TeleportUI.Areas.List
        -- Areas.List has UIListLayout and UICorner as children too — use FindFirstChild
        local areaFrame=areaList:FindFirstChild(areaName)
        if not areaFrame then return end
        local main=areaFrame:FindFirstChild("Main") if not main then return end
        -- Title check: locked by purchase shows LOCKED
        local title=main:FindFirstChild("Title")
        if not title then return end
        if title.Text:upper():find("LOCKED") then return end
        -- Level check: parse range or minimum
        local levelLbl=main:FindFirstChild("Level")
        if levelLbl then
            local txt=levelLbl.Text:gsub("<[^>]+>",""):upper()
            -- Format 'LEVEL 0-19': player must be <= 19 (max of range)
            -- Format 'LEVEL 420+': player must be >= 420
            -- Format 'LEVEL 10+': player must be >= 10
            local lo,hi=txt:match("(%d+)-(%d+)")
            if lo and hi then
                -- Range format: player must be within [lo, hi]
                local plvl=getPlayerLevel()
                if plvl>0 then
                    if plvl<tonumber(lo) or plvl>tonumber(hi) then return end
                end
            else
                local min=txt:match("(%d+)%+") or txt:match("(%d+)")
                if min then
                    local req=tonumber(min) or 0
                    if req>0 then
                        local plvl=getPlayerLevel()
                        if plvl>0 and plvl<req then return end
                    end
                end
            end
        end
        result=true
    end)
    if result then unlockedCache[areaName]=true end
    return result
end

