local function isAtBase()
    local char=localplr.Character if not char then return true end
    local rp=char:FindFirstChild("HumanoidRootPart") if not rp then return true end
    local npcs=workspace:FindFirstChild("NPCs") if not npcs then return true end
    for _,obj in ipairs(npcs:GetChildren()) do
        for _,n in ipairs(TARGET_NAMES) do
            if obj.Name==n then
                local h=obj:FindFirstChildWhichIsA("Humanoid")
                if h and h.Health>0 and (rp.Position-obj:GetPivot().Position).Magnitude<MAX_TARGET_DISTANCE then
                    return false
                end
            end
        end
    end
    return true
end

